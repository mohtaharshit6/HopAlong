# Copy to .env and fill in values. All EXPO_PUBLIC_ vars are safe to expose in the client bundle.

EXPO_PUBLIC_API_URL=http://10.0.2.2:5000
EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-mobile-restricted-key
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
