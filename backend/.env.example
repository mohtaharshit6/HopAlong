# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# Supabase (Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase (Settings > API)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Razorpay (Dashboard > API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-here

# Google Maps (GCP Console — server-restricted key)
GOOGLE_MAPS_SERVER_KEY=your-google-maps-server-key-here

# Twilio (console.twilio.com — Account Info panel)
# Leave blank to fall back to console-logging OTPs (dev mode)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Flask
SECRET_KEY=change-this-to-a-random-secret-string
FLASK_ENV=development
